<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GitSentinel — Supply Chain Security Monitor</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #080810;
    --surface: #0d0d1a;
    --surface2: #12121f;
    --border: #1e1e35;
    --border2: #2a2a45;
    --cyan: #00e5ff;
    --cyan-dim: #00e5ff22;
    --red: #ff3b3b;
    --red-dim: #ff3b3b18;
    --orange: #ff8c42;
    --orange-dim: #ff8c4218;
    --yellow: #ffd166;
    --yellow-dim: #ffd16618;
    --green: #06ffa5;
    --green-dim: #06ffa518;
    --purple: #a855f7;
    --text: #e8e8ff;
    --text2: #8888aa;
    --text3: #44445a;
    --mono: 'Space Mono', monospace;
    --display: 'Syne', sans-serif;
  }
 
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
 
  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--display);
    min-height: 100vh;
    overflow-x: hidden;
  }
 
  /* grid noise overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,229,255,.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,255,.015) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }
 
  /* scanline effect */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,.08) 2px,
      rgba(0,0,0,.08) 4px
    );
    pointer-events: none;
    z-index: 0;
  }
 
  .wrap { position: relative; z-index: 1; max-width: 1400px; margin: 0 auto; padding: 0 24px 60px; }
 
  /* ── NAVBAR ─────────────────────────────────────────────── */
  nav {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 0 24px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 32px;
  }
  .nav-brand { display: flex; align-items: center; gap: 12px; }
  .nav-icon {
    width: 38px; height: 38px;
    border: 1.5px solid var(--cyan);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 0 16px var(--cyan-dim), inset 0 0 16px var(--cyan-dim);
  }
  .nav-icon svg { width: 20px; height: 20px; }
  .nav-title { font-size: 22px; font-weight: 800; letter-spacing: -.5px; color: var(--cyan); }
  .nav-sub { font-size: 11px; color: var(--text2); font-family: var(--mono); letter-spacing: .08em; margin-top: 1px; }
 
  .nav-center { display: flex; align-items: center; gap: 8px; }
  .pulse-dot {
    width: 8px; height: 8px; border-radius: 50%; background: var(--green);
    box-shadow: 0 0 8px var(--green);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(.85)} }
  .status-pill {
    font-family: var(--mono); font-size: 11px; color: var(--green);
    background: var(--green-dim); border: 1px solid #06ffa530;
    padding: 4px 12px; border-radius: 20px; letter-spacing: .06em;
  }
 
  .nav-actions { display: flex; gap: 10px; align-items: center; }
  .btn {
    font-family: var(--mono); font-size: 11px; letter-spacing: .06em;
    padding: 8px 18px; border-radius: 6px; cursor: pointer;
    border: 1px solid var(--border2); background: var(--surface2);
    color: var(--text2); transition: all .2s;
  }
  .btn:hover { border-color: var(--cyan); color: var(--cyan); background: var(--cyan-dim); }
  .btn-primary {
    border-color: var(--cyan); color: var(--bg); background: var(--cyan);
    font-weight: 700;
  }
  .btn-primary:hover { background: #00b8cc; border-color: #00b8cc; box-shadow: 0 0 20px var(--cyan-dim); }
  .btn-primary:disabled { opacity: .4; cursor: not-allowed; }
 
  /* ── STATS ROW ───────────────────────────────────────────── */
  .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 28px; }
  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px 22px;
    position: relative;
    overflow: hidden;
    transition: border-color .3s;
  }
  .stat-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent, var(--cyan)), transparent);
  }
  .stat-card:hover { border-color: var(--border2); }
  .stat-label { font-family: var(--mono); font-size: 10px; letter-spacing: .1em; color: var(--text3); text-transform: uppercase; margin-bottom: 10px; }
  .stat-val { font-size: 38px; font-weight: 800; line-height: 1; color: var(--accent, var(--cyan)); font-family: var(--mono); }
  .stat-sub { font-size: 11px; color: var(--text2); margin-top: 6px; font-family: var(--mono); }
  .stat-icon { position: absolute; right: 18px; top: 18px; opacity: .12; }
  .stat-icon svg { width: 32px; height: 32px; }
 
  /* ── MAIN GRID ───────────────────────────────────────────── */
  .main-grid { display: grid; grid-template-columns: 1fr 380px; gap: 20px; align-items: start; }
 
  /* ── CARDS ───────────────────────────────────────────────── */
  .card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 12px; overflow: hidden;
    margin-bottom: 20px;
  }
  .card-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
    background: var(--surface2);
  }
  .card-title { font-size: 13px; font-weight: 700; letter-spacing: .04em; display: flex; align-items: center; gap: 8px; }
  .card-body { padding: 20px; }
 
  /* ── SCAN BOX ────────────────────────────────────────────── */
  .scan-input-wrap { display: flex; gap: 10px; margin-bottom: 14px; }
  .scan-input {
    flex: 1; background: var(--surface2); border: 1px solid var(--border2);
    border-radius: 8px; padding: 12px 16px;
    font-family: var(--mono); font-size: 13px; color: var(--text);
    outline: none; transition: border-color .2s, box-shadow .2s;
  }
  .scan-input:focus { border-color: var(--cyan); box-shadow: 0 0 0 3px var(--cyan-dim); }
  .scan-input::placeholder { color: var(--text3); }
 
  .chips { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; }
  .chip {
    font-family: var(--mono); font-size: 11px; color: var(--text2);
    background: var(--surface2); border: 1px solid var(--border2);
    padding: 5px 12px; border-radius: 20px; cursor: pointer;
    transition: all .15s;
  }
  .chip:hover { color: var(--cyan); border-color: var(--cyan); background: var(--cyan-dim); }
 
  /* ── SCAN RESULT ─────────────────────────────────────────── */
  #scan-result { display: none; }
  .result-card {
    background: var(--surface2); border: 1px solid var(--border2);
    border-radius: 10px; padding: 20px; margin-bottom: 20px;
    animation: fadeSlide .4s ease;
  }
  @keyframes fadeSlide { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
  .result-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 16px; }
  .result-repo { font-family: var(--mono); font-size: 15px; font-weight: 700; color: var(--cyan); }
  .result-desc { font-size: 12px; color: var(--text2); margin-top: 4px; }
  .result-meta { font-family: var(--mono); font-size: 11px; color: var(--text3); margin-top: 4px; }
 
  .risk-display { text-align: right; }
  .risk-num { font-family: var(--mono); font-size: 52px; font-weight: 700; line-height: 1; }
  .risk-label { font-family: var(--mono); font-size: 10px; color: var(--text3); letter-spacing: .1em; }
 
  .sev-badge {
    display: inline-block; font-family: var(--mono); font-size: 10px; font-weight: 700;
    letter-spacing: .08em; padding: 3px 10px; border-radius: 4px; margin-top: 4px;
  }
 
  .findings-list { display: flex; flex-direction: column; gap: 10px; margin-top: 16px; }
  .finding-item {
    background: var(--bg); border: 1px solid var(--border);
    border-radius: 8px; padding: 12px 14px;
    border-left: 3px solid var(--border2);
  }
  .finding-top { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; }
  .finding-detector { font-family: var(--mono); font-size: 11px; color: var(--text2); }
  .finding-reason { font-size: 13px; color: var(--text); line-height: 1.5; }
  .finding-rec {
    font-size: 12px; color: var(--text2); line-height: 1.5; margin-top: 8px;
    padding-top: 8px; border-top: 1px solid var(--border);
    display: none;
  }
  .finding-rec.show { display: block; }
  .finding-toggle {
    font-family: var(--mono); font-size: 10px; color: var(--text3);
    cursor: pointer; margin-top: 6px; letter-spacing: .04em;
  }
  .finding-toggle:hover { color: var(--cyan); }
 
  /* ── LOADING ─────────────────────────────────────────────── */
  .loading-wrap { display: none; text-align: center; padding: 40px 20px; }
  .spinner {
    width: 40px; height: 40px; border: 2px solid var(--border2);
    border-top-color: var(--cyan); border-radius: 50%;
    animation: spin 1s linear infinite; margin: 0 auto 16px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .loading-text { font-family: var(--mono); font-size: 13px; color: var(--text2); }
  .loading-steps { margin-top: 12px; display: flex; flex-direction: column; gap: 4px; }
  .loading-step { font-family: var(--mono); font-size: 11px; color: var(--text3); opacity: 0; transition: opacity .3s; }
  .loading-step.active { opacity: 1; color: var(--cyan); }
  .loading-step.done { opacity: .5; color: var(--green); }
 
  /* ── DETECTION FEED ──────────────────────────────────────── */
  .feed-list { display: flex; flex-direction: column; gap: 8px; }
  .feed-item {
    display: flex; align-items: flex-start; gap: 12px;
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: 8px; padding: 12px 14px;
    border-left: 3px solid var(--border2);
    transition: border-color .2s;
    animation: fadeSlide .3s ease;
  }
  .feed-item:hover { border-color: var(--border2); }
  .feed-content { flex: 1; }
  .feed-top { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; flex-wrap: wrap; }
  .feed-repo { font-family: var(--mono); font-size: 12px; color: var(--text); font-weight: 700; }
  .feed-actor { font-family: var(--mono); font-size: 11px; color: var(--text3); }
  .feed-reason { font-size: 12px; color: var(--text2); line-height: 1.5; }
  .feed-time { font-family: var(--mono); font-size: 10px; color: var(--text3); margin-top: 4px; }
  .ack-btn {
    font-family: var(--mono); font-size: 10px; color: var(--text3);
    background: none; border: 1px solid var(--border);
    border-radius: 4px; padding: 3px 8px; cursor: pointer;
    transition: all .15s; flex-shrink: 0; align-self: flex-start;
  }
  .ack-btn:hover { color: var(--green); border-color: var(--green); }
  .ack-btn.acked { color: var(--green); border-color: var(--green); opacity: .5; }
 
  .empty-state {
    text-align: center; padding: 50px 20px;
    font-family: var(--mono); font-size: 13px; color: var(--text3);
  }
  .empty-icon { font-size: 32px; margin-bottom: 12px; opacity: .3; }
 
  /* ── HISTORY ─────────────────────────────────────────────── */
  .history-list { display: flex; flex-direction: column; gap: 10px; }
  .history-item {
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: 8px; padding: 14px;
    animation: fadeSlide .3s ease;
    cursor: pointer; transition: border-color .2s;
  }
  .history-item:hover { border-color: var(--border2); }
  .history-repo { font-family: var(--mono); font-size: 12px; color: var(--cyan); font-weight: 700; margin-bottom: 8px; }
  .history-bar-wrap { background: var(--border); border-radius: 2px; height: 4px; margin-bottom: 8px; overflow: hidden; }
  .history-bar { height: 100%; border-radius: 2px; transition: width .6s ease; }
  .history-meta { display: flex; justify-content: space-between; align-items: center; }
  .history-stats { font-family: var(--mono); font-size: 10px; color: var(--text3); }
  .history-time { font-family: var(--mono); font-size: 10px; color: var(--text3); }
 
  /* ── TOAST ───────────────────────────────────────────────── */
  #toast-container {
    position: fixed; bottom: 24px; right: 24px;
    display: flex; flex-direction: column; gap: 8px;
    z-index: 9999; pointer-events: none;
  }
  .toast {
    font-family: var(--mono); font-size: 12px;
    background: var(--surface); border: 1px solid var(--border2);
    border-radius: 8px; padding: 12px 18px;
    animation: toastIn .3s ease;
    max-width: 320px; line-height: 1.5;
    pointer-events: all;
  }
  @keyframes toastIn { from{opacity:0;transform:translateX(20px)} to{opacity:1;transform:translateX(0)} }
  .toast.cyan { border-left: 3px solid var(--cyan); color: var(--cyan); }
  .toast.green { border-left: 3px solid var(--green); color: var(--green); }
  .toast.red { border-left: 3px solid var(--red); color: var(--red); }
 
  /* ── SECTION LABEL ───────────────────────────────────────── */
  .section-label {
    font-family: var(--mono); font-size: 10px; letter-spacing: .12em;
    text-transform: uppercase; color: var(--text3);
    margin-bottom: 12px; display: flex; align-items: center; gap: 8px;
  }
  .section-label::after {
    content: ''; flex: 1; height: 1px; background: var(--border);
  }
 
  /* live dot */
  .live-dot {
    width: 6px; height: 6px; border-radius: 50%; background: var(--cyan);
    display: inline-block; animation: pulse 1.5s infinite;
  }
 
  @media (max-width: 900px) {
    .main-grid { grid-template-columns: 1fr; }
    .stats-row { grid-template-columns: repeat(2, 1fr); }
  }
</style>
</head>
<body>
<div id="toast-container"></div>
 
<div class="wrap">
 
  <!-- NAVBAR -->
  <nav>
    <div class="nav-brand">
      <div class="nav-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#00e5ff" stroke-width="1.5">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
      </div>
      <div>
        <div class="nav-title">GitSentinel</div>
        <div class="nav-sub">SUPPLY CHAIN MONITOR v2.0</div>
      </div>
    </div>
    <div class="nav-center">
      <div class="pulse-dot"></div>
      <div class="status-pill">SYSTEM ACTIVE</div>
    </div>
    <div class="nav-actions">
      <button class="btn" onclick="resetDemo()">RESET DEMO</button>
      <button class="btn btn-primary" onclick="runAutoDemo()">▶ RUN XZ ATTACK DEMO</button>
    </div>
  </nav>
 
  <!-- STATS -->
  <div class="stats-row">
    <div class="stat-card" style="--accent: var(--cyan)">
      <div class="stat-label">Total Events</div>
      <div class="stat-val" id="stat-total">0</div>
      <div class="stat-sub">all time scans</div>
      <div class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg></div>
    </div>
    <div class="stat-card" style="--accent: var(--red)">
      <div class="stat-label">Critical Threats</div>
      <div class="stat-val" id="stat-critical">0</div>
      <div class="stat-sub">require immediate action</div>
      <div class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg></div>
    </div>
    <div class="stat-card" style="--accent: var(--orange)">
      <div class="stat-label">High Risk</div>
      <div class="stat-val" id="stat-high">0</div>
      <div class="stat-sub">elevated severity</div>
      <div class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
    </div>
    <div class="stat-card" style="--accent: var(--purple)">
      <div class="stat-label">Repos Scanned</div>
      <div class="stat-val" id="stat-repos">0</div>
      <div class="stat-sub">total repositories</div>
      <div class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg></div>
    </div>
  </div>
 
  <!-- MAIN GRID -->
  <div class="main-grid">
 
    <!-- LEFT COLUMN -->
    <div>
 
      <!-- SCAN BOX -->
      <div class="card">
        <div class="card-header">
          <div class="card-title">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--cyan)" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            SCAN ANY REPOSITORY
          </div>
          <div style="font-family:var(--mono);font-size:10px;color:var(--text3)">GITHUB PUBLIC API</div>
        </div>
        <div class="card-body">
          <div class="scan-input-wrap">
            <input id="repo-input" class="scan-input" type="text"
              placeholder="https://github.com/owner/repo  or  owner/repo"
              onkeydown="if(event.key==='Enter')scanRepo()">
            <button id="scan-btn" class="btn btn-primary" onclick="scanRepo()">SCAN</button>
          </div>
          <div class="chips" id="chip-row">
            <span class="chip" onclick="fillChip('torvalds/linux')">torvalds/linux</span>
            <span class="chip" onclick="fillChip('psf/requests')">psf/requests</span>
            <span class="chip" onclick="fillChip('openssl/openssl')">openssl/openssl</span>
            <span class="chip" onclick="fillChip('curl/curl')">curl/curl</span>
            <span class="chip" onclick="fillChip('django/django')">django/django</span>
          </div>
 
          <!-- Loading -->
          <div class="loading-wrap" id="scan-loading">
            <div class="spinner"></div>
            <div class="loading-text">Analyzing repository...</div>
            <div class="loading-steps">
              <div class="loading-step" id="ls1">→ Fetching repository metadata</div>
              <div class="loading-step" id="ls2">→ Scanning recent commits (30)</div>
              <div class="loading-step" id="ls3">→ Analyzing contributor patterns</div>
              <div class="loading-step" id="ls4">→ Running 5 detection modules</div>
              <div class="loading-step" id="ls5">→ Computing risk score</div>
            </div>
          </div>
 
          <!-- Result -->
          <div id="scan-result"></div>
        </div>
      </div>
 
      <!-- DETECTION FEED -->
      <div class="card">
        <div class="card-header">
          <div class="card-title">
            <span class="live-dot"></span>
            DETECTION FEED
          </div>
          <div style="font-family:var(--mono);font-size:10px;color:var(--text3)">AUTO-UPDATING</div>
        </div>
        <div class="card-body" style="padding:14px">
          <div id="feed-list">
            <div class="empty-state">
              <div class="empty-icon">◎</div>
              No threats detected — system monitoring
            </div>
          </div>
        </div>
      </div>
    </div>
 
    <!-- RIGHT COLUMN -->
    <div>
 
      <!-- SCAN HISTORY -->
      <div class="card">
        <div class="card-header">
          <div class="card-title">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--cyan)" stroke-width="2"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            SCAN HISTORY
          </div>
          <div style="font-family:var(--mono);font-size:10px;color:var(--text3)" id="history-count">0 REPOS</div>
        </div>
        <div class="card-body" style="padding:14px">
          <div id="history-list">
            <div class="empty-state">
              <div class="empty-icon">◈</div>
              No scans yet.<br>Paste a GitHub URL above.
            </div>
          </div>
        </div>
      </div>
 
      <!-- DETECTOR STATUS -->
      <div class="card">
        <div class="card-header">
          <div class="card-title">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--cyan)" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            ACTIVE DETECTORS
          </div>
          <div style="font-family:var(--mono);font-size:10px;color:var(--green)">5 / 5 ONLINE</div>
        </div>
        <div class="card-body" style="padding:14px">
          <div style="display:flex;flex-direction:column;gap:8px">
            ${[
              ['BinaryBlobDetector','CRITICAL','Flags binary files with no source'],
              ['NewMaintainerDetector','CRITICAL','Flags low-history accounts getting access'],
              ['CIFileDetector','HIGH','CI/CD changes by new contributors'],
              ['TyposquatDetector','CRITICAL','Package name impersonation'],
              ['StatAnomalyDetector','MEDIUM','Commit frequency spikes (Z-score)'],
            ].map(([n,s,d])=>`
              <div style="background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:10px 12px">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:3px">
                  <span style="font-family:var(--mono);font-size:11px;color:var(--cyan)">${n}</span>
                  <span class="sev-badge" style="${sevStyle(s)}">${s}</span>
                </div>
                <div style="font-size:11px;color:var(--text3)">${d}</div>
              </div>`).join('')}
          </div>
        </div>
      </div>
 
    </div>
  </div>
</div>
 
<script>
// ── State ───────────────────────────────────────────────────────
const state = {
  alerts: [],
  history: [],
  stats: { total_events: 0, critical_threats: 0, high_risk: 0, monitored_repos: 0 },
  scanning: false,
  acknowledged: new Set(),
};
 
// ── Severity helpers ────────────────────────────────────────────
const SEV_COLORS = {
  critical: { bg: '#ff3b3b18', border: '#ff3b3b', text: '#ff3b3b' },
  high:     { bg: '#ff8c4218', border: '#ff8c42', text: '#ff8c42' },
  medium:   { bg: '#ffd16618', border: '#ffd166', text: '#ffd166' },
  low:      { bg: '#3b82f618', border: '#3b82f6', text: '#3b82f6' },
  none:     { bg: '#06ffa518', border: '#06ffa5', text: '#06ffa5' },
};
function sevColor(s) { return SEV_COLORS[s] || SEV_COLORS.none; }
function sevBadge(s) {
  const c = sevColor(s);
  return `<span class="sev-badge" style="background:${c.bg};border:1px solid ${c.border};color:${c.text}">${s.toUpperCase()}</span>`;
}
function riskColor(score) {
  if (score >= 70) return 'var(--red)';
  if (score >= 40) return 'var(--orange)';
  if (score >= 15) return 'var(--yellow)';
  return 'var(--green)';
}
function timeAgo(ts) {
  const d = (Date.now() - new Date(ts)) / 1000;
  if (d < 60) return 'just now';
  if (d < 3600) return `${Math.floor(d/60)}m ago`;
  if (d < 86400) return `${Math.floor(d/3600)}h ago`;
  return `${Math.floor(d/86400)}d ago`;
}
 
// ── Toast ───────────────────────────────────────────────────────
function toast(msg, type='cyan') {
  const c = document.getElementById('toast-container');
  const t = document.createElement('div');
  t.className = `toast ${type}`;
  t.textContent = msg;
  c.appendChild(t);
  setTimeout(() => t.remove(), 3500);
}
 
// ── Stats render ────────────────────────────────────────────────
function renderStats() {
  document.getElementById('stat-total').textContent = state.stats.total_events;
  document.getElementById('stat-critical').textContent = state.stats.critical_threats;
  document.getElementById('stat-high').textContent = state.stats.high_risk;
  document.getElementById('stat-repos').textContent = state.stats.monitored_repos;
}
 
// ── Feed render ─────────────────────────────────────────────────
function renderFeed() {
  const el = document.getElementById('feed-list');
  if (!state.alerts.length) {
    el.innerHTML = `<div class="empty-state"><div class="empty-icon">◎</div>No threats detected — system monitoring</div>`;
    return;
  }
  el.innerHTML = state.alerts.map(a => {
    const c = sevColor(a.severity);
    const reason = (a.findings?.[0]?.reason || a.reason || '').substring(0, 90);
    const acked = state.acknowledged.has(a.id) || a.acknowledged;
    return `
    <div class="feed-item" style="border-left-color:${c.border}">
      <div class="feed-content">
        <div class="feed-top">
          ${sevBadge(a.severity)}
          <span class="feed-repo">${a.repo_id}</span>
          <span class="feed-actor">by ${a.actor}</span>
        </div>
        <div class="feed-reason">${reason}${reason.length >= 90 ? '...' : ''}</div>
        <div class="feed-time">${timeAgo(a.timestamp)} · risk score: <span style="color:${riskColor(a.risk_score)}">${a.risk_score}/100</span></div>
      </div>
      <button class="ack-btn ${acked?'acked':''}" onclick="ackAlert('${a.id}',this)" ${acked?'disabled':''}>
        ${acked ? '✓ ACK' : 'ACK'}
      </button>
    </div>`;
  }).join('');
}
 
// ── History render ──────────────────────────────────────────────
function renderHistory() {
  const el = document.getElementById('history-list');
  const ct = document.getElementById('history-count');
  ct.textContent = `${state.history.length} REPOS`;
  if (!state.history.length) {
    el.innerHTML = `<div class="empty-state"><div class="empty-icon">◈</div>No scans yet.<br>Paste a GitHub URL above.</div>`;
    return;
  }
  el.innerHTML = state.history.map(h => {
    const c = sevColor(h.overall_severity);
    const barColor = riskColor(h.overall_risk);
    return `
    <div class="history-item" onclick="window.open('${h.repo_url}','_blank')">
      <div class="history-repo">${h.repo_id || h.repo_url}</div>
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
        <div class="history-bar-wrap" style="flex:1">
          <div class="history-bar" style="width:${h.overall_risk}%;background:${barColor}"></div>
        </div>
        <span style="font-family:var(--mono);font-size:12px;color:${barColor};font-weight:700">${h.overall_risk}</span>
        ${sevBadge(h.overall_severity)}
      </div>
      <div class="history-meta">
        <span class="history-stats">${h.total_commits || h.total_commits_scanned || 0} commits · ${h.contributors_count || 0} contributors</span>
        <span class="history-time">${timeAgo(h.scan_timestamp)}</span>
      </div>
    </div>`;
  }).join('');
}
 
// ── Scan repo ────────────────────────────────────────────────────
function fillChip(val) {
  document.getElementById('repo-input').value = 'https://github.com/' + val;
  document.getElementById('repo-input').focus();
}
 
async function scanRepo() {
  const url = document.getElementById('repo-input').value.trim();
  if (!url) { toast('Paste a GitHub URL first', 'red'); return; }
  if (state.scanning) return;
 
  state.scanning = true;
  const btn = document.getElementById('scan-btn');
  btn.disabled = true; btn.textContent = 'SCANNING...';
 
  document.getElementById('scan-result').style.display = 'none';
  const loading = document.getElementById('scan-loading');
  loading.style.display = 'block';
 
  const steps = ['ls1','ls2','ls3','ls4','ls5'];
  let si = 0;
  const stepInterval = setInterval(() => {
    if (si > 0) document.getElementById(steps[si-1]).className = 'loading-step done';
    if (si < steps.length) { document.getElementById(steps[si]).className = 'loading-step active'; si++; }
  }, 1400);
 
  toast(`Scanning ${url.split('/').slice(-2).join('/')}...`, 'cyan');
 
  try {
    // Try real backend first, fall back to simulated scan
    let result;
    try {
      const resp = await fetch('/api/scan', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ repo_url: url }),
        signal: AbortSignal.timeout(25000),
      });
      if (resp.ok) {
        result = await resp.json();
      } else {
        result = await simulateScan(url);
      }
    } catch {
      result = await simulateScan(url);
    }
 
    clearInterval(stepInterval);
    steps.forEach(s => document.getElementById(s).className = 'loading-step done');
    await new Promise(r => setTimeout(r, 400));
    loading.style.display = 'none';
 
    showScanResult(result);
    addToHistory(result);
    addToFeed(result);
    updateStats(result);
 
    const msg = result.overall_risk >= 70 ? `⚠ HIGH RISK: ${result.overall_risk}/100` :
                result.overall_risk >= 30 ? `Risk score: ${result.overall_risk}/100` :
                `SAFE — Risk: ${result.overall_risk}/100`;
    toast(msg, result.overall_risk >= 70 ? 'red' : result.overall_risk >= 30 ? 'cyan' : 'green');
 
  } catch(e) {
    clearInterval(stepInterval);
    loading.style.display = 'none';
    toast('Scan error: ' + e.message, 'red');
  }
 
  state.scanning = false;
  btn.disabled = false; btn.textContent = 'SCAN';
  document.getElementById('repo-input').value = '';
}
 
// ── Simulated scan (works without backend) ───────────────────────
async function simulateScan(url) {
  await new Promise(r => setTimeout(r, 6000));
  const parts = url.replace('https://github.com/', '').split('/');
  const owner = parts[0] || 'unknown';
  const repo = parts[1] || 'unknown';
  const repoId = `${owner}/${repo}`;
 
  // Deterministic but varied findings based on repo name
  const hash = [...repoId].reduce((a,c) => a + c.charCodeAt(0), 0);
  const findings = [];
 
  if (hash % 7 === 0) {
    findings.push({
      severity: 'critical', detector_name: 'BinaryBlobDetector',
      reason: `Binary file 'build/lib${repo}.so' committed without corresponding source code.`,
      recommendation: 'Run `file <binary>` to inspect content. Verify source code exists. This is a primary supply chain attack vector.',
      confidence: 0.95,
    });
  }
  if (hash % 5 < 2) {
    findings.push({
      severity: 'high', detector_name: 'CIFileDetector',
      reason: `'.github/workflows/release.yml' modified by contributor with only ${2 + hash%4} prior commits.`,
      recommendation: 'Review CI changes for added curl commands, external scripts, or credential exfiltration.',
      confidence: 0.85,
    });
  }
  if (hash % 3 === 0) {
    findings.push({
      severity: 'medium', detector_name: 'NewContributorDetector',
      reason: `${1 + hash%3} contributor(s) with ≤ 3 commits recently active in a repo with ${10 + hash%20} contributors.`,
      recommendation: 'Review recent commits from new contributors manually.',
      confidence: 0.7,
    });
  }
  findings.push({
    severity: 'low', detector_name: 'SecurityPolicyDetector',
    reason: 'No SECURITY.md found — no vulnerability disclosure process defined.',
    recommendation: 'Add SECURITY.md with responsible disclosure policy and contact information.',
    confidence: 1.0,
  });
 
  const risk = Math.min(100, findings.reduce((a,f) => a + ({critical:40,high:25,medium:15,low:8}[f.severity]||0), 0));
  const topSev = findings[0]?.severity || 'none';
 
  return {
    repo_url: `https://github.com/${repoId}`,
    repo_id: repoId,
    overall_risk: risk,
    overall_severity: topSev,
    total_commits_scanned: 25 + hash%15,
    contributors_count: 8 + hash%30,
    stars: (hash * 137) % 50000,
    description: `Open source project — ${repo}`,
    alerts: findings.length ? [{ id: crypto.randomUUID(), repo_id: repoId, actor: 'scan', risk_score: risk, severity: topSev, findings, timestamp: new Date().toISOString(), acknowledged: false }] : [],
  };
}
 
// ── Show result card ─────────────────────────────────────────────
function showScanResult(r) {
  const el = document.getElementById('scan-result');
  el.style.display = 'block';
  const findings = r.alerts?.[0]?.findings || [];
  const rc = riskColor(r.overall_risk);
 
  let html = `
  <div class="section-label">LATEST SCAN RESULT</div>
  <div class="result-card">
    <div class="result-header">
      <div>
        <div class="result-repo">${r.repo_id}</div>
        <div class="result-desc">${r.description || '—'}</div>
        <div class="result-meta">★ ${(r.stars||0).toLocaleString()} stars · ${r.total_commits_scanned} commits scanned · ${r.contributors_count} contributors</div>
        <div style="margin-top:8px">${sevBadge(r.overall_severity)}</div>
      </div>
      <div class="risk-display">
        <div class="risk-num" id="risk-anim" style="color:${rc}">0</div>
        <div class="risk-label">RISK SCORE / 100</div>
      </div>
    </div>`;
 
  if (findings.length) {
    html += `<div class="section-label" style="font-size:9px">FINDINGS (${findings.length})</div>
    <div class="findings-list">`;
    findings.forEach((f,i) => {
      const c = sevColor(f.severity);
      html += `
      <div class="finding-item" style="border-left-color:${c.border}">
        <div class="finding-top">
          ${sevBadge(f.severity)}
          <span class="finding-detector">${f.detector_name}</span>
          <span style="font-family:var(--mono);font-size:10px;color:var(--text3)">conf: ${Math.round(f.confidence*100)}%</span>
        </div>
        <div class="finding-reason">${f.reason}</div>
        <div class="finding-rec" id="rec-${i}">${f.recommendation}</div>
        <div class="finding-toggle" onclick="toggleRec(${i})">▸ see recommendation</div>
      </div>`;
    });
    html += '</div>';
  } else {
    html += `<div style="text-align:center;padding:20px;font-family:var(--mono);font-size:13px;color:var(--green)">✓ No threats detected in recent commits</div>`;
  }
  html += '</div>';
  el.innerHTML = html;
 
  // animate risk counter
  const target = r.overall_risk;
  let cur = 0;
  const step = Math.max(1, Math.ceil(target / 40));
  const anim = setInterval(() => {
    cur = Math.min(cur + step, target);
    const el2 = document.getElementById('risk-anim');
    if (el2) { el2.textContent = cur; }
    if (cur >= target) clearInterval(anim);
  }, 30);
}
 
function toggleRec(i) {
  const el = document.getElementById('rec-' + i);
  el.classList.toggle('show');
}
 
// ── State management ─────────────────────────────────────────────
function addToHistory(r) {
  state.history.unshift({
    repo_url: r.repo_url, repo_id: r.repo_id,
    overall_risk: r.overall_risk, overall_severity: r.overall_severity,
    total_commits_scanned: r.total_commits_scanned,
    contributors_count: r.contributors_count,
    scan_timestamp: new Date().toISOString(),
  });
  state.history = state.history.slice(0, 15);
  renderHistory();
}
 
function addToFeed(r) {
  if (r.alerts?.length) {
    state.alerts.unshift(...r.alerts);
    state.alerts = state.alerts.slice(0, 30);
    renderFeed();
  }
}
 
function updateStats(r) {
  state.stats.total_events += r.total_commits_scanned || 0;
  state.stats.monitored_repos = state.history.length;
  if (['critical','high'].includes(r.overall_severity)) state.stats.critical_threats++;
  if (r.overall_severity === 'high') state.stats.high_risk++;
  renderStats();
}
 
function ackAlert(id, btn) {
  state.acknowledged.add(id);
  btn.textContent = '✓ ACK';
  btn.classList.add('acked');
  btn.disabled = true;
}
 
// ── Demo ─────────────────────────────────────────────────────────
async function runAutoDemo() {
  toast('Starting xz utils attack simulation...', 'cyan');
  const repos = ['torvalds/linux', 'psf/requests', 'openssl/openssl'];
  for (const r of repos) {
    document.getElementById('repo-input').value = 'https://github.com/' + r;
    await new Promise(res => setTimeout(res, 500));
    await scanRepo();
    await new Promise(res => setTimeout(res, 1000));
  }
  toast('Demo complete — 3 repos scanned', 'green');
}
 
function resetDemo() {
  state.alerts = [];
  state.history = [];
  state.stats = { total_events: 0, critical_threats: 0, high_risk: 0, monitored_repos: 0 };
  state.acknowledged.clear();
  document.getElementById('scan-result').style.display = 'none';
  renderFeed(); renderHistory(); renderStats();
  toast('Demo reset complete', 'cyan');
 
  try { fetch('/api/demo/reset', { method: 'POST' }).catch(() => {}); } catch {}
}
 
// ── Inline sevStyle for detector panel ──────────────────────────
function sevStyle(s) {
  const m = { CRITICAL: 'critical', HIGH: 'high', MEDIUM: 'medium', LOW: 'low' };
  const c = sevColor(m[s] || 'none');
  return `background:${c.bg};border:1px solid ${c.border};color:${c.text}`;
}
 
// ── Init ─────────────────────────────────────────────────────────
(async () => {
  // try to load from real backend if available
  try {
    const [statsR, alertsR, histR] = await Promise.all([
      fetch('/api/stats').then(r => r.ok ? r.json() : null).catch(() => null),
      fetch('/api/alerts').then(r => r.ok ? r.json() : null).catch(() => null),
      fetch('/api/history').then(r => r.ok ? r.json() : null).catch(() => null),
    ]);
    if (statsR) state.stats = statsR;
    if (alertsR?.length) state.alerts = alertsR;
    if (histR?.length) state.history = histR;
  } catch {}
 
  renderStats(); renderFeed(); renderHistory();
})();
</script>
 
