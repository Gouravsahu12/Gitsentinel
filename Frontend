<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GitSentinel</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=JetBrains+Mono:wght@300;400;500;700&family=Figtree:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#020409;
  --glass:rgba(8,12,28,0.6);
  --glass2:rgba(255,255,255,0.04);
  --border:rgba(255,255,255,0.07);
  --border2:rgba(0,212,170,0.25);
  --mint:#00d4aa;
  --mint-dim:rgba(0,212,170,0.1);
  --red:#ff2d55;
  --red-dim:rgba(255,45,85,0.12);
  --orange:#ff6b2b;
  --orange-dim:rgba(255,107,43,0.12);
  --yellow:#ffd60a;
  --yellow-dim:rgba(255,214,10,0.12);
  --blue:#0a84ff;
  --blue-dim:rgba(10,132,255,0.12);
  --text:#f0f4ff;
  --text2:#8892b0;
  --text3:#3a4060;
  --mono:'JetBrains Mono',monospace;
  --display:'Bebas Neue',sans-serif;
  --body:'Figtree',sans-serif;
}
html{scroll-behavior:smooth}
body{
  background:var(--bg);
  color:var(--text);
  font-family:var(--body);
  min-height:100vh;
  overflow-x:hidden;
  cursor:none;
}

/* ── CUSTOM CURSOR ─────────────────────────────────────── */
#cursor{
  position:fixed;width:20px;height:20px;
  border:1.5px solid var(--mint);
  border-radius:50%;pointer-events:none;z-index:9999;
  transform:translate(-50%,-50%);
  transition:transform .08s ease,width .2s,height .2s,border-color .2s,background .2s;
}
#cursor-dot{
  position:fixed;width:4px;height:4px;
  background:var(--mint);border-radius:50%;
  pointer-events:none;z-index:9999;
  transform:translate(-50%,-50%);
  transition:transform .04s ease;
}
body:has(button:hover) #cursor,
body:has(a:hover) #cursor{
  width:40px;height:40px;
  background:rgba(0,212,170,0.08);
  border-color:var(--mint);
}

/* ── THREE.JS CANVAS ───────────────────────────────────── */
#bg{
  position:fixed;inset:0;z-index:0;
  pointer-events:none;
}

/* ── FLOATING ORBS ─────────────────────────────────────── */
.orbs{position:fixed;inset:0;z-index:1;pointer-events:none;overflow:hidden}
.orb{
  position:absolute;border-radius:50%;filter:blur(80px);
  animation:float linear infinite;
  transform-origin:center;
}
.orb1{width:600px;height:600px;background:radial-gradient(circle,rgba(0,212,170,.07),transparent 70%);top:-200px;right:-150px;animation-duration:25s}
.orb2{width:500px;height:500px;background:radial-gradient(circle,rgba(255,45,85,.05),transparent 70%);bottom:-100px;left:-200px;animation-duration:30s;animation-delay:-10s}
.orb3{width:400px;height:400px;background:radial-gradient(circle,rgba(10,132,255,.06),transparent 70%);top:40%;left:40%;animation-duration:20s;animation-delay:-5s}
.orb4{width:300px;height:300px;background:radial-gradient(circle,rgba(255,107,43,.04),transparent 70%);top:20%;left:60%;animation-duration:35s;animation-delay:-15s}

@keyframes float{
  0%{transform:translate(0,0) scale(1)}
  25%{transform:translate(30px,-40px) scale(1.05)}
  50%{transform:translate(-20px,30px) scale(.95)}
  75%{transform:translate(40px,20px) scale(1.02)}
  100%{transform:translate(0,0) scale(1)}
}

/* ── PAGE WRAPPER ──────────────────────────────────────── */
.page{position:relative;z-index:2;max-width:1440px;margin:0 auto;padding:0 28px 80px}

/* ── GLASS MIXIN ───────────────────────────────────────── */
.glass{
  background:var(--glass);
  backdrop-filter:blur(24px) saturate(160%);
  -webkit-backdrop-filter:blur(24px) saturate(160%);
  border:1px solid var(--border);
  box-shadow:0 8px 32px rgba(0,0,0,.5),inset 0 1px 0 rgba(255,255,255,0.04);
}
.glass-tilt{
  transition:transform .15s ease,box-shadow .15s ease;
  transform:perspective(1200px) rotateX(0) rotateY(0) translateZ(0);
  will-change:transform;
}
.glass-tilt:hover{
  box-shadow:0 20px 60px rgba(0,0,0,.6),0 0 40px rgba(0,212,170,.06),inset 0 1px 0 rgba(255,255,255,0.06);
}

/* ── NAVBAR ────────────────────────────────────────────── */
nav{
  display:flex;align-items:center;justify-content:space-between;
  padding:24px 0 28px;
  border-bottom:1px solid var(--border);
  margin-bottom:36px;
}
.brand{display:flex;align-items:center;gap:16px}
.logo-wrap{position:relative;width:44px;height:44px}
.logo-ring{
  position:absolute;inset:0;
  border:1.5px solid var(--mint);
  border-radius:10px;
  animation:ring-spin 8s linear infinite;
  box-shadow:0 0 20px rgba(0,212,170,.3),inset 0 0 20px rgba(0,212,170,.05);
}
@keyframes ring-spin{0%{transform:rotate(0)}100%{transform:rotate(360deg)}}
.logo-inner{
  position:absolute;inset:4px;
  background:rgba(0,212,170,.08);
  border-radius:7px;
  display:flex;align-items:center;justify-content:center;
}
.logo-inner svg{width:20px;height:20px;filter:drop-shadow(0 0 6px var(--mint))}
.brand-text .name{
  font-family:var(--display);
  font-size:26px;letter-spacing:.08em;
  color:var(--mint);
  text-shadow:0 0 30px rgba(0,212,170,.5);
  line-height:1;
}
.brand-text .tagline{
  font-family:var(--mono);font-size:9px;
  color:var(--text3);letter-spacing:.2em;
  text-transform:uppercase;margin-top:3px;
}

.nav-mid{display:flex;align-items:center;gap:16px}
.status-wrap{
  display:flex;align-items:center;gap:8px;
  padding:7px 16px;border-radius:20px;
  background:rgba(6,255,165,.06);
  border:1px solid rgba(6,255,165,.15);
}
.pulse{
  width:7px;height:7px;border-radius:50%;
  background:#06ffa5;
  box-shadow:0 0 10px #06ffa5;
  animation:pulse-anim 2s ease-in-out infinite;
}
@keyframes pulse-anim{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.7)}}
.status-text{font-family:var(--mono);font-size:11px;color:#06ffa5;letter-spacing:.08em}
.time-display{
  font-family:var(--mono);font-size:12px;color:var(--text3);
  padding:6px 14px;border-radius:6px;
  background:rgba(255,255,255,.02);
  border:1px solid var(--border);
  letter-spacing:.06em;
}

.nav-right{display:flex;gap:10px;align-items:center}
.btn{
  font-family:var(--mono);font-size:11px;letter-spacing:.08em;
  padding:9px 20px;border-radius:7px;cursor:none;
  border:1px solid var(--border);
  background:rgba(255,255,255,.03);
  color:var(--text2);
  transition:all .2s;
  position:relative;overflow:hidden;
}
.btn::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(255,255,255,.04),transparent);
  opacity:0;transition:opacity .2s;
}
.btn:hover{border-color:rgba(0,212,170,.4);color:var(--mint);background:rgba(0,212,170,.05)}
.btn:hover::before{opacity:1}
.btn-accent{
  border-color:var(--mint);color:var(--bg);
  background:var(--mint);font-weight:700;
  box-shadow:0 0 20px rgba(0,212,170,.3);
}
.btn-accent:hover{background:#00f0c0;box-shadow:0 0 30px rgba(0,212,170,.5);color:var(--bg)}
.btn-accent:disabled{opacity:.35;cursor:not-allowed;box-shadow:none}

/* ── STATS ──────────────────────────────────────────────── */
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:32px}
.stat{
  border-radius:14px;padding:22px 24px;
  position:relative;overflow:hidden;
  animation:rise .6s ease both;
}
.stat::after{
  content:'';position:absolute;
  top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--accent-color,var(--mint)) 50%,transparent);
  opacity:.6;
}
.stat-bg-glow{
  position:absolute;top:-40px;right:-40px;
  width:120px;height:120px;border-radius:50%;
  background:var(--accent-color,var(--mint));
  opacity:.04;filter:blur(30px);
  pointer-events:none;
}
.stat-label{font-family:var(--mono);font-size:9px;letter-spacing:.15em;text-transform:uppercase;color:var(--text3);margin-bottom:12px}
.stat-num{
  font-family:var(--display);font-size:52px;line-height:1;
  color:var(--accent-color,var(--mint));
  text-shadow:0 0 40px var(--accent-color,rgba(0,212,170,.4));
  letter-spacing:.02em;
}
.stat-foot{font-size:12px;color:var(--text2);margin-top:6px}
@keyframes rise{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

/* ── MAIN GRID ──────────────────────────────────────────── */
.grid{display:grid;grid-template-columns:1fr 400px;gap:20px;align-items:start}

/* ── SECTION ────────────────────────────────────────────── */
.section{border-radius:16px;margin-bottom:20px;overflow:hidden;animation:rise .5s ease both}
.sec-head{
  display:flex;align-items:center;justify-content:space-between;
  padding:16px 22px;
  border-bottom:1px solid var(--border);
  background:rgba(0,0,0,.2);
}
.sec-title{
  font-family:var(--mono);font-size:11px;font-weight:700;
  letter-spacing:.12em;text-transform:uppercase;
  display:flex;align-items:center;gap:8px;
  color:var(--text);
}
.sec-badge{
  font-family:var(--mono);font-size:9px;letter-spacing:.1em;
  padding:3px 10px;border-radius:20px;text-transform:uppercase;
}
.sec-body{padding:20px}

/* ── SCAN INPUT ─────────────────────────────────────────── */
.scan-field{
  display:flex;gap:12px;margin-bottom:16px;
}
.scan-input{
  flex:1;
  background:rgba(255,255,255,.03);
  border:1px solid var(--border2);
  border-radius:10px;padding:14px 18px;
  font-family:var(--mono);font-size:13px;color:var(--text);
  outline:none;
  transition:border-color .2s,box-shadow .2s,background .2s;
  caret-color:var(--mint);
}
.scan-input:focus{
  border-color:var(--mint);
  background:rgba(0,212,170,.04);
  box-shadow:0 0 0 3px rgba(0,212,170,.08),0 0 20px rgba(0,212,170,.05);
}
.scan-input::placeholder{color:var(--text3)}

.chips{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:22px}
.chip{
  font-family:var(--mono);font-size:10px;color:var(--text2);
  background:rgba(255,255,255,.03);
  border:1px solid var(--border);
  padding:5px 13px;border-radius:20px;
  cursor:none;transition:all .15s;letter-spacing:.04em;
}
.chip:hover{color:var(--mint);border-color:rgba(0,212,170,.4);background:rgba(0,212,170,.07);transform:translateY(-1px)}

/* ── LOADER ─────────────────────────────────────────────── */
#loader{display:none;padding:40px 20px}
.loader-inner{display:flex;flex-direction:column;align-items:center;gap:20px}
.loader-orb{
  width:64px;height:64px;border-radius:50%;
  border:2px solid rgba(0,212,170,.15);
  border-top-color:var(--mint);
  animation:spin 1s linear infinite;
  position:relative;
  box-shadow:0 0 20px rgba(0,212,170,.15);
}
.loader-orb::after{
  content:'';position:absolute;inset:6px;
  border-radius:50%;
  border:1px solid rgba(0,212,170,.1);
  border-bottom-color:var(--mint);
  animation:spin .7s linear infinite reverse;
}
@keyframes spin{to{transform:rotate(360deg)}}
.loader-txt{font-family:var(--mono);font-size:13px;color:var(--text2);letter-spacing:.06em}
.loader-steps{display:flex;flex-direction:column;gap:5px;min-width:260px}
.lstep{
  display:flex;align-items:center;gap:10px;
  font-family:var(--mono);font-size:11px;color:var(--text3);
  transition:all .3s;padding:4px 0;
}
.lstep.active{color:var(--mint)}
.lstep.done{color:rgba(6,255,165,.5)}
.lstep .dot{width:5px;height:5px;border-radius:50%;background:currentColor;flex-shrink:0}

/* ── RESULT CARD ────────────────────────────────────────── */
#result-wrap{display:none}
.result-panel{
  border-radius:12px;padding:22px;margin-bottom:20px;
  border:1px solid var(--border2);
  background:linear-gradient(135deg,rgba(0,212,170,.05),rgba(0,0,0,.3));
  position:relative;overflow:hidden;
  animation:fadeUp .5s ease both;
}
.result-panel::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--mint),transparent);
}
@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.result-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:18px}
.result-repo-name{font-family:var(--mono);font-size:17px;font-weight:700;color:var(--mint);margin-bottom:5px;word-break:break-all}
.result-desc{font-size:13px;color:var(--text2);line-height:1.5;margin-bottom:6px}
.result-meta{font-family:var(--mono);font-size:11px;color:var(--text3)}

.risk-dial{text-align:right;flex-shrink:0;margin-left:20px}
.risk-big{font-family:var(--display);font-size:72px;line-height:1;letter-spacing:.02em;transition:color .3s}
.risk-unit{font-family:var(--mono);font-size:10px;color:var(--text3);letter-spacing:.15em;margin-top:2px}

.findings{display:flex;flex-direction:column;gap:10px;margin-top:16px}
.finding{
  border-radius:10px;padding:14px 16px;
  border-left:3px solid;
  background:rgba(0,0,0,.3);
  border-color:var(--f-color,var(--border));
  animation:fadeUp .4s ease both;
}
.find-top{display:flex;align-items:center;gap:10px;margin-bottom:7px;flex-wrap:wrap}
.find-name{font-family:var(--mono);font-size:11px;color:var(--text2);letter-spacing:.04em}
.find-reason{font-size:13px;color:var(--text);line-height:1.6}
.find-rec{
  font-size:12px;color:var(--text2);line-height:1.6;
  margin-top:10px;padding-top:10px;
  border-top:1px solid var(--border);
  display:none;
}
.find-rec.show{display:block}
.find-toggle{
  font-family:var(--mono);font-size:10px;color:var(--text3);
  cursor:none;margin-top:7px;transition:color .15s;display:inline-block;
}
.find-toggle:hover{color:var(--mint)}

/* ── SEVERITY BADGE ─────────────────────────────────────── */
.badge{
  font-family:var(--mono);font-size:9px;font-weight:700;
  letter-spacing:.1em;padding:3px 10px;border-radius:4px;
  text-transform:uppercase;flex-shrink:0;
}

/* ── FEED ───────────────────────────────────────────────── */
.feed{display:flex;flex-direction:column;gap:8px}
.feed-item{
  display:flex;align-items:flex-start;gap:12px;
  border-radius:10px;padding:13px 15px;
  border-left:3px solid;
  background:rgba(0,0,0,.25);
  transition:background .2s,transform .2s;
  animation:slideIn .35s ease both;
  cursor:default;
}
.feed-item:hover{background:rgba(255,255,255,.02);transform:translateX(3px)}
@keyframes slideIn{from{opacity:0;transform:translateX(-10px)}to{opacity:1;transform:translateX(0)}}
.feed-body{flex:1;min-width:0}
.feed-row1{display:flex;align-items:center;gap:8px;margin-bottom:4px;flex-wrap:wrap}
.feed-repo{font-family:var(--mono);font-size:12px;font-weight:700;color:var(--text)}
.feed-actor{font-family:var(--mono);font-size:10px;color:var(--text3)}
.feed-reason{font-size:12px;color:var(--text2);line-height:1.5;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.feed-time{font-family:var(--mono);font-size:10px;color:var(--text3);margin-top:4px}
.ack-btn{
  font-family:var(--mono);font-size:10px;
  background:none;border:1px solid var(--border);
  border-radius:5px;padding:3px 9px;cursor:none;
  color:var(--text3);transition:all .15s;flex-shrink:0;
  letter-spacing:.05em;
}
.ack-btn:hover{color:var(--mint);border-color:var(--mint)}
.ack-btn.done{color:rgba(0,212,170,.5);border-color:rgba(0,212,170,.2);opacity:.6}

.empty{
  text-align:center;padding:50px 20px;
  font-family:var(--mono);font-size:12px;color:var(--text3);
  letter-spacing:.06em;
}

/* ── HISTORY CARD ───────────────────────────────────────── */
.hist-item{
  border-radius:10px;padding:15px;
  background:rgba(255,255,255,.02);
  border:1px solid var(--border);
  cursor:none;transition:all .2s;
  animation:fadeUp .4s ease both;
  margin-bottom:10px;
  transform:perspective(600px) rotateX(0) rotateY(0);
}
.hist-item:hover{
  border-color:rgba(0,212,170,.2);
  background:rgba(0,212,170,.03);
}
.hist-repo{font-family:var(--mono);font-size:12px;font-weight:700;color:var(--mint);margin-bottom:10px;word-break:break-all}
.hist-bar-bg{height:3px;background:rgba(255,255,255,.06);border-radius:2px;margin-bottom:8px;overflow:hidden}
.hist-bar{height:100%;border-radius:2px;transition:width .8s cubic-bezier(.34,1.56,.64,1)}
.hist-foot{display:flex;justify-content:space-between;align-items:center}
.hist-stats{font-family:var(--mono);font-size:10px;color:var(--text3)}
.hist-time{font-family:var(--mono);font-size:10px;color:var(--text3)}

/* ── DETECTOR LIST ──────────────────────────────────────── */
.det-item{
  border-radius:9px;padding:12px 14px;
  background:rgba(255,255,255,.02);
  border:1px solid var(--border);
  margin-bottom:8px;
}
.det-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:4px}
.det-name{font-family:var(--mono);font-size:11px;color:var(--mint);font-weight:500}
.det-desc{font-size:11px;color:var(--text3);line-height:1.4}

/* ── TOAST ──────────────────────────────────────────────── */
#toasts{position:fixed;bottom:28px;right:28px;z-index:9998;display:flex;flex-direction:column;gap:10px;pointer-events:none}
.toast{
  font-family:var(--mono);font-size:12px;letter-spacing:.04em;
  backdrop-filter:blur(20px);background:rgba(8,12,28,.9);
  border:1px solid var(--border);border-radius:10px;
  padding:13px 20px;max-width:340px;line-height:1.5;
  pointer-events:all;
  animation:toastIn .3s cubic-bezier(.34,1.56,.64,1);
  box-shadow:0 8px 32px rgba(0,0,0,.6);
}
@keyframes toastIn{from{opacity:0;transform:translateX(30px) scale(.95)}to{opacity:1;transform:translateX(0) scale(1)}}
.toast.mint{border-left:3px solid var(--mint);color:var(--mint)}
.toast.red{border-left:3px solid var(--red);color:var(--red)}
.toast.green{border-left:3px solid #06ffa5;color:#06ffa5}

/* ── FLOATING 3D BADGE ──────────────────────────────────── */
.float-badge{
  position:fixed;bottom:100px;right:28px;z-index:8;
  padding:10px 16px;border-radius:10px;
  background:rgba(0,212,170,.08);
  border:1px solid rgba(0,212,170,.2);
  backdrop-filter:blur(20px);
  font-family:var(--mono);font-size:10px;color:var(--mint);
  letter-spacing:.08em;
  animation:floatBadge 4s ease-in-out infinite;
  pointer-events:none;
}
@keyframes floatBadge{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}

@media(max-width:1000px){
  .grid{grid-template-columns:1fr}
  .stats{grid-template-columns:repeat(2,1fr)}
}
</style>
</head>
<body>

<div id="cursor"></div>
<div id="cursor-dot"></div>

<canvas id="bg"></canvas>

<div class="orbs">
  <div class="orb orb1"></div>
  <div class="orb orb2"></div>
  <div class="orb orb3"></div>
  <div class="orb orb4"></div>
</div>

<div class="float-badge">⬡ LIVE MONITORING</div>

<div id="toasts"></div>

<div class="page">

  <!-- NAVBAR -->
  <nav>
    <div class="brand">
      <div class="logo-wrap">
        <div class="logo-ring"></div>
        <div class="logo-inner">
          <svg viewBox="0 0 24 24" fill="none" stroke="#00d4aa" stroke-width="1.5">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
      </div>
      <div class="brand-text">
        <div class="name">GITSENTINEL</div>
        <div class="tagline">SUPPLY CHAIN SECURITY MONITOR · v2.0</div>
      </div>
    </div>
    <div class="nav-mid">
      <div class="status-wrap">
        <div class="pulse"></div>
        <div class="status-text">SYSTEM ONLINE</div>
      </div>
      <div class="time-display" id="clock">--:--:--</div>
    </div>
    <div class="nav-right">
      <button class="btn" onclick="resetDemo()">RESET DEMO</button>
      <button class="btn btn-accent" onclick="runDemo()">▶ RUN XZ DEMO</button>
    </div>
  </nav>

  <!-- STATS -->
  <div class="stats">
    <div class="stat glass glass-tilt" style="--accent-color:var(--mint)" data-delay="0">
      <div class="stat-bg-glow"></div>
