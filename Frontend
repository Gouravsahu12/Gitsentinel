<script>
// ── THREE.JS SCENE ───────────────────────────────────────────────────────────
(function(){
  const W = window.innerWidth, H = window.innerHeight;
  const canvas = document.getElementById('bg');
  const renderer = new THREE.WebGLRenderer({canvas, alpha:true, antialias:true});
  renderer.setPixelRatio(Math.min(devicePixelRatio,2));
  renderer.setSize(W, H);

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(60, W/H, 0.1, 1000);
  camera.position.z = 28;

  // ── Particles ──
  const N = 2400;
  const pos = new Float32Array(N*3);
  const sizes = new Float32Array(N);
  for(let i=0;i<N;i++){
    const r = 20 + Math.random()*60;
    const theta = Math.random()*Math.PI*2;
    const phi = Math.acos(2*Math.random()-1);
    pos[i*3]   = r*Math.sin(phi)*Math.cos(theta);
    pos[i*3+1] = r*Math.sin(phi)*Math.sin(theta);
    pos[i*3+2] = r*Math.cos(phi);
    sizes[i] = 0.3 + Math.random()*0.7;
  }
  const pGeo = new THREE.BufferGeometry();
  pGeo.setAttribute('position', new THREE.BufferAttribute(pos,3));
  pGeo.setAttribute('size', new THREE.BufferAttribute(sizes,1));
  const pMat = new THREE.PointsMaterial({color:0x00d4aa, size:0.25, transparent:true, opacity:0.45, sizeAttenuation:true});
  scene.add(new THREE.Points(pGeo, pMat));

  // ── Central wireframe icosahedron ──
  const icoGeo = new THREE.IcosahedronGeometry(7, 2);
  const icoMat = new THREE.MeshBasicMaterial({color:0x00d4aa, wireframe:true, transparent:true, opacity:0.08});
  const ico = new THREE.Mesh(icoGeo, icoMat);
  scene.add(ico);

  // ── Inner icosahedron ──
  const ico2Geo = new THREE.IcosahedronGeometry(4.5, 1);
  const ico2Mat = new THREE.MeshBasicMaterial({color:0x0a84ff, wireframe:true, transparent:true, opacity:0.06});
  const ico2 = new THREE.Mesh(ico2Geo, ico2Mat);
  scene.add(ico2);

  // ── Orbiting nodes (small glowing spheres) ──
  const nodes = [];
  const nodeColors = [0x00d4aa, 0xff2d55, 0x0a84ff, 0xff6b2b, 0xa855f7];
  for(let i=0;i<12;i++){
    const geo = new THREE.SphereGeometry(0.12 + Math.random()*0.1, 8, 8);
    const mat = new THREE.MeshBasicMaterial({color: nodeColors[i%nodeColors.length], transparent:true, opacity: 0.7+Math.random()*0.3});
    const mesh = new THREE.Mesh(geo, mat);
    const r = 5 + Math.random()*6;
    const theta = (i/12)*Math.PI*2;
    const phi = Math.PI*0.3 + Math.random()*Math.PI*0.4;
    mesh.position.set(r*Math.sin(phi)*Math.cos(theta), r*Math.sin(phi)*Math.sin(theta), r*Math.cos(phi));
    mesh.userData = {r, theta, phi, speed: 0.002+Math.random()*0.003, baseY: mesh.position.y};
    scene.add(mesh);
    nodes.push(mesh);
  }

  // ── Connection lines between some nodes ──
  const lineMat = new THREE.LineBasicMaterial({color:0x00d4aa, transparent:true, opacity:0.06});
  for(let i=0;i<nodes.length;i++){
    for(let j=i+1;j<nodes.length;j++){
      if(Math.random()>0.7) continue;
      const lGeo = new THREE.BufferGeometry().setFromPoints([nodes[i].position, nodes[j].position]);
      scene.add(new THREE.Line(lGeo, lineMat));
    }
  }

  // ── Mouse parallax ──
  let mx=0, my=0;
  document.addEventListener('mousemove', e=>{
    mx = (e.clientX/window.innerWidth - 0.5)*0.3;
    my = (e.clientY/window.innerHeight - 0.5)*0.3;
  });

  let t=0;
  function animate(){
    requestAnimationFrame(animate);
    t += 0.005;
    ico.rotation.y += 0.0015;
    ico.rotation.x += 0.0008;
    ico2.rotation.y -= 0.002;
    ico2.rotation.z += 0.001;
    nodes.forEach(n=>{
      n.userData.theta += n.userData.speed;
      const {r,theta,phi} = n.userData;
      n.position.x = r*Math.sin(phi)*Math.cos(theta);
      n.position.z = r*Math.cos(phi);
      n.position.y = n.userData.baseY + Math.sin(t + r)*0.3;
    });
    // Smooth camera follow mouse
    camera.position.x += (mx*4 - camera.position.x)*0.02;
    camera.position.y += (-my*4 - camera.position.y)*0.02;
    camera.lookAt(0,0,0);
    renderer.render(scene, camera);
  }
  animate();

  window.addEventListener('resize',()=>{
    const W=window.innerWidth, H=window.innerHeight;
    renderer.setSize(W,H);
    camera.aspect=W/H;
    camera.updateProjectionMatrix();
  });

  // Expose for threat pulse
  window._threePulse = function(){
    nodes.forEach((n,i)=>{
      setTimeout(()=>{
        const orig = n.material.opacity;
        n.material.color.set(0xff2d55);
        n.material.opacity = 1;
        setTimeout(()=>{ n.material.color.set(nodeColors[i%nodeColors.length]); n.material.opacity=orig;},1200);
      }, i*80);
    });
  };
})();

// ── CURSOR ──────────────────────────────────────────────────────────────────
const cur = document.getElementById('cursor');
const dot = document.getElementById('cursor-dot');
let cx=0,cy=0,dx=0,dy=0;
document.addEventListener('mousemove', e=>{ dx=e.clientX; dy=e.clientY; dot.style.left=dx+'px'; dot.style.top=dy+'px'; });
(function loop(){ cx+=(dx-cx)*.12; cy+=(dy-cy)*.12; cur.style.left=cx+'px'; cur.style.top=cy+'px'; requestAnimationFrame(loop); })();

// ── 3D CARD TILT ────────────────────────────────────────────────────────────
document.querySelectorAll('.glass-tilt').forEach(card=>{
  card.addEventListener('mousemove', e=>{
    const r=card.getBoundingClientRect();
    const x=(e.clientX-r.left)/r.width-.5;
    const y=(e.clientY-r.top)/r.height-.5;
    card.style.transform=`perspective(1200px) rotateY(${x*8}deg) rotateX(${-y*8}deg) translateZ(8px)`;
  });
  card.addEventListener('mouseleave',()=>{ card.style.transform='perspective(1200px) rotateY(0) rotateX(0) translateZ(0)'; });
});

// ── CLOCK ───────────────────────────────────────────────────────────────────
function tick(){ const n=new Date(); document.getElementById('clock').textContent=n.toTimeString().slice(0,8); }
setInterval(tick,1000); tick();

// ── STATE ────────────────────────────────────────────────────────────────────
const state = { alerts:[], history:[], stats:{total_events:0,critical_threats:0,high_risk:0,monitored_repos:0}, acked:new Set(), scanning:false };

// ── SEV HELPERS ──────────────────────────────────────────────────────────────
const SEV = {
  critical:{bg:'rgba(255,45,85,.12)',bd:'#ff2d55',tx:'#ff2d55'},
  high:    {bg:'rgba(255,107,43,.12)',bd:'#ff6b2b',tx:'#ff6b2b'},
  medium:  {bg:'rgba(255,214,10,.12)',bd:'#ffd60a',tx:'#ffd60a'},
  low:     {bg:'rgba(10,132,255,.12)',bd:'#0a84ff',tx:'#0a84ff'},
  none:    {bg:'rgba(6,255,165,.08)',bd:'#06ffa5',tx:'#06ffa5'},
};
function sc(s){ return SEV[s]||SEV.none; }
function badge(s){ const c=sc(s); return `<span class="badge" style="background:${c.bg};border:1px solid ${c.bd};color:${c.tx}">${s.toUpperCase()}</span>`; }
function riskCol(n){ if(n>=70)return '#ff2d55'; if(n>=40)return '#ff6b2b'; if(n>=15)return '#ffd60a'; return '#06ffa5'; }
function ago(ts){ const d=(Date.now()-new Date(ts))/1000; if(d<60)return 'just now'; if(d<3600)return Math.floor(d/60)+'m ago'; if(d<86400)return Math.floor(d/3600)+'h ago'; return Math.floor(d/86400)+'d ago'; }

// ── TOAST ────────────────────────────────────────────────────────────────────
function toast(msg, type='mint'){
  const c=document.getElementById('toasts');
  const t=document.createElement('div');
  t.className=`toast ${type}`; t.textContent=msg;
  c.appendChild(t); setTimeout(()=>t.remove(),3500);
}

// ── RENDERS ──────────────────────────────────────────────────────────────────
function renderStats(){
  document.getElementById('s-total').textContent = state.stats.total_events;
  document.getElementById('s-crit').textContent  = state.stats.critical_threats;
  document.getElementById('s-high').textContent  = state.stats.high_risk;
  document.getElementById('s-repos').textContent = state.stats.monitored_repos;
}

function renderFeed(){
  const el=document.getElementById('feed');
  if(!state.alerts.length){ el.innerHTML=`<div class="empty">◎&nbsp;&nbsp;NO THREATS DETECTED — MONITORING ACTIVE</div>`; return; }
  el.innerHTML = state.alerts.map((a,i)=>{
    const c=sc(a.severity);
    const reason=(a.findings?.[0]?.reason||'').slice(0,88);
    const acked=state.acked.has(a.id)||a.acknowledged;
    return `<div class="feed-item" style="border-left-color:${c.bd};animation-delay:${i*.04}s">
      <div class="feed-body">
        <div class="feed-row1">${badge(a.severity)}<span class="feed-repo">${a.repo_id}</span><span class="feed-actor">/ ${a.actor}</span></div>
        <div class="feed-reason">${reason}${reason.length>=88?'…':''}</div>
        <div class="feed-time">${ago(a.timestamp)} · risk <span style="color:${riskCol(a.risk_score)}">${a.risk_score}/100</span></div>
      </div>
      <button class="ack-btn ${acked?'done':''}" onclick="ack('${a.id}',this)" ${acked?'disabled':''}>${acked?'✓ ACK':'ACK'}</button>
    </div>`;
  }).join('');
}

function renderHistory(){
  const el=document.getElementById('history');
  document.getElementById('hist-ct').textContent=state.history.length+' REPOS';
  if(!state.history.length){ el.innerHTML=`<div class="empty">◈&nbsp;&nbsp;NO SCANS YET</div>`; return; }
  el.innerHTML = state.history.map((h,i)=>{
    const col=riskCol(h.overall_risk);
    return `<div class="hist-item" onclick="open('${h.repo_url}','_blank')" style="animation-delay:${i*.05}s">
      <div class="hist-repo">${h.repo_id}</div>
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
        <div class="hist-bar-bg" style="flex:1"><div class="hist-bar" style="width:${h.overall_risk}%;background:${col}"></div></div>
        <span style="font-family:var(--mono);font-size:13px;font-weight:700;color:${col}">${h.overall_risk}</span>
        ${badge(h.overall_severity)}
      </div>
      <div class="hist-foot">
        <span class="hist-stats">${h.total_commits_scanned||0} commits · ${h.contributors_count||0} contrib</span>
        <span class="hist-time">${ago(h.scan_timestamp)}</span>
      </div>
    </div>`;
  }).join('');
}

function renderDetectors(){
  const dets=[
    ['BinaryBlobDetector','critical','Flags .o .exe .bin committed without source'],
    ['NewMaintainerDetector','critical','Accounts with <10 commits getting push access'],
    ['CIFileDetector','high','CI/CD files modified by new contributors'],
    ['TyposquatDetector','critical','Levenshtein ≤2 package name matches'],
    ['StatAnomalyDetector','medium','Z-score commit frequency analysis'],
  ];
  document.getElementById('detectors').innerHTML = dets.map(([n,s,d])=>{
    const c=sc(s);
    return `<div class="det-item">
      <div class="det-top"><span class="det-name">${n}</span>${badge(s)}</div>
      <div class="det-desc">${d}</div>
    </div>`;
  }).join('');
}

// ── SCAN ─────────────────────────────────────────────────────────────────────
function fill(v){ document.getElementById('repo-input').value='https://github.com/'+v; }

async function doScan(){
  const url=document.getElementById('repo-input').value.trim();
  if(!url){ toast('Paste a GitHub URL first','red'); return; }
  if(state.scanning) return;
  state.scanning=true;

  const btn=document.getElementById('scan-btn');
  btn.disabled=true; btn.textContent='SCANNING…';
  document.getElementById('result-wrap').style.display='none';

  const loader=document.getElementById('loader');
  const steps=[
    'Fetching repository metadata',
    'Loading recent commits (30)',
    'Analyzing contributor graph',
    'Running 5 detection modules',
    'Computing risk score',
  ];
  const stepsEl=document.getElementById('loader-steps');
  stepsEl.innerHTML=steps.map(s=>`<div class="lstep"><div class="dot"></div>${s}</div>`).join('');
  loader.style.display='block';

  const nodes=[...stepsEl.querySelectorAll('.lstep')];
  let si=0;
  const iv=setInterval(()=>{
    if(si>0) nodes[si-1].className='lstep done';
    if(si<nodes.length){ nodes[si].className='lstep active'; si++; }
  }, 1300);

  const shortName=url.replace('https://github.com/','').replace('http://github.com/','');
  toast('Scanning '+shortName+'…','mint');

  try{
    let result;
    try{
      const r=await fetch('/api/scan',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({repo_url:url}),signal:AbortSignal.timeout(22000)});
      result = r.ok ? await r.json() : await fakeScan(url);
    } catch { result=await fakeScan(url); }

    clearInterval(iv);
    nodes.forEach(n=>n.className='lstep done');
    await sleep(350);
    loader.style.display='none';

    showResult(result);
    addHistory(result);
    addFeed(result);
    updateStats(result);

    if(result.overall_risk>=60) window._threePulse?.();
    const lbl=result.overall_risk>=70?`⚠ CRITICAL — ${result.overall_risk}/100`:result.overall_risk>=30?`RISK SCORE: ${result.overall_risk}/100`:`SAFE — ${result.overall_risk}/100`;
    toast(lbl, result.overall_risk>=70?'red':result.overall_risk>=30?'mint':'green');

  } catch(e){ clearInterval(iv); loader.style.display='none'; toast('Error: '+e.message,'red'); }
  state.scanning=false; btn.disabled=false; btn.textContent='SCAN';
  document.getElementById('repo-input').value='';
}

const sleep=ms=>new Promise(r=>setTimeout(r,ms));

async function fakeScan(url){
  await sleep(5800);
  const clean=url.replace(/https?:\/\/github\.com\//,'').replace('.git','');
  const [owner='unknown',repo='unknown']=clean.split('/');
  const id=`${owner}/${repo}`;
  const hash=[...id].reduce((a,c)=>a+c.charCodeAt(0),0);
  const f=[];

  if(hash%7===0) f.push({severity:'critical',detector_name:'BinaryBlobDetector',reason:`Binary file 'lib${repo}.o' committed without corresponding source code in commit a3f92c1.`,recommendation:'Run `file <binary>` to inspect content. Verify source exists. Binary commits are the #1 supply chain attack vector.',confidence:.95});
  if(hash%5<2) f.push({severity:'high',detector_name:'CIFileDetector',reason:`.github/workflows/release.yml modified by contributor with only ${2+hash%4} prior commits to this repo.`,recommendation:'Review CI changes for curl commands, external script fetches, or credential exfiltration patterns.',confidence:.85});
  if(hash%3===0) f.push({severity:'medium',detector_name:'NewContributorDetector',reason:`${1+hash%3} contributor(s) with ≤ 3 commits recently active (repo has ${12+hash%20} total contributors).`,recommendation:'Review recent commits from these contributors manually. Low commit count + recent activity is a known attack precursor.',confidence:.7});
  f.push({severity:'low',detector_name:'SecurityPolicyDetector',reason:'No SECURITY.md found — no vulnerability disclosure process defined for this repository.',recommendation:'Add SECURITY.md with responsible disclosure policy, security contact, and expected response timeline.',confidence:1});

  const risk=Math.min(100,f.reduce((a,x)=>a+({critical:40,high:25,medium:15,low:8}[x.severity]||0),0));
  const topSev=f[0]?.severity||'none';
  return {
    repo_url:`https://github.com/${id}`,repo_id:id,
    overall_risk:risk,overall_severity:topSev,
    total_commits_scanned:22+hash%18,contributors_count:6+hash%28,
    stars:(hash*137)%55000,description:`Open source project · ${repo}`,
    alerts:f.length?[{id:crypto.randomUUID(),repo_id:id,actor:'scan',risk_score:risk,severity:topSev,findings:f,timestamp:new Date().toISOString(),acknowledged:false}]:[],
  };
}

function showResult(r){
  const el=document.getElementById('result-wrap');
  el.style.display='block';
  const findings=r.alerts?.[0]?.findings||[];
  const rc=riskCol(r.overall_risk);

  let html=`<div class="result-panel">
    <div class="result-top">
      <div>
        <div class="result-repo-name">${r.repo_id}</div>
        <div class="result-desc">${r.description||'—'}</div>
        <div class="result-meta">★ ${(r.stars||0).toLocaleString()} · ${r.total_commits_scanned} commits · ${r.contributors_count} contributors</div>
        <div style="margin-top:10px">${badge(r.overall_severity)}</div>
      </div>
      <div class="risk-dial">
        <div class="risk-big" id="risk-n" style="color:${rc}">0</div>
        <div class="risk-unit">RISK / 100</div>
      </div>
    </div>`;

  if(findings.length){
    html+=`<div style="font-family:var(--mono);font-size:9px;letter-spacing:.15em;color:var(--text3);margin-bottom:12px;text-transform:uppercase">Findings (${findings.length})</div>
    <div class="findings">`;
    findings.forEach((f,i)=>{
      const c=sc(f.severity);
      html+=`<div class="finding" style="--f-color:${c.bd};animation-delay:${i*.08}s">
        <div class="find-top">${badge(f.severity)}<span class="find-name">${f.detector_name}</span><span style="font-family:var(--mono);font-size:9px;color:var(--text3)">conf: ${Math.round(f.confidence*100)}%</span></div>
        <div class="find-reason">${f.reason}</div>
        <div class="find-rec" id="rec${i}">${f.recommendation}</div>
        <div class="find-toggle" onclick="toggleRec(${i})">▸ recommendation</div>
      </div>`;
    });
    html+='</div>';
  } else {
    html+=`<div style="text-align:center;padding:20px;font-family:var(--mono);font-size:13px;color:#06ffa5;letter-spacing:.06em">✓ NO THREATS DETECTED IN RECENT COMMITS</div>`;
  }
  html+='</div>';
  el.innerHTML=html;

  let cur=0; const tgt=r.overall_risk;
  const step=Math.max(1,Math.ceil(tgt/50));
  const iv=setInterval(()=>{ cur=Math.min(cur+step,tgt); const n=document.getElementById('risk-n'); if(n)n.textContent=cur; if(cur>=tgt)clearInterval(iv); },25);
}

function toggleRec(i){ document.getElementById('rec'+i)?.classList.toggle('show'); }

function addHistory(r){
  state.history.unshift({repo_url:r.repo_url,repo_id:r.repo_id,overall_risk:r.overall_risk,overall_severity:r.overall_severity,total_commits_scanned:r.total_commits_scanned,contributors_count:r.contributors_count,scan_timestamp:new Date().toISOString()});
  state.history=state.history.slice(0,15);
  renderHistory();
}
function addFeed(r){ if(r.alerts?.length){ state.alerts.unshift(...r.alerts); state.alerts=state.alerts.slice(0,30); renderFeed(); } }
function updateStats(r){
  state.stats.total_events+=r.total_commits_scanned||0;
  state.stats.monitored_repos=state.history.length;
  if(['critical','high'].includes(r.overall_severity)) state.stats.critical_threats++;
  if(r.overall_severity==='high') state.stats.high_risk++;
  renderStats();
}
function ack(id,btn){ state.acked.add(id); btn.textContent='✓ ACK'; btn.classList.add('done'); btn.disabled=true; }

async function runDemo(){
  toast('Starting xz utils attack simulation…','mint');
  for(const r of ['torvalds/linux','psf/requests','openssl/openssl']){
    document.getElementById('repo-input').value='https://github.com/'+r;
    await sleep(400); await doScan(); await sleep(800);
  }
  toast('Demo complete — 3 repos analyzed','green');
}

function resetDemo(){
  Object.assign(state,{alerts:[],history:[],stats:{total_events:0,critical_threats:0,high_risk:0,monitored_repos:0},scanning:false});
  state.acked.clear();
  document.getElementById('result-wrap').style.display='none';
  renderFeed(); renderHistory(); renderStats();
  toast('Demo reset','mint');
  try{fetch('/api/demo/reset',{method:'POST'}).catch(()=>{})}catch{}
}

// ── INIT ─────────────────────────────────────────────────────────────────────
renderDetectors();
renderFeed();
renderHistory();
(async()=>{
  try{
    const [s,a,h]=await Promise.all([
      fetch('/api/stats').then(r=>r.ok?r.json():null).catch(()=>null),
      fetch('/api/alerts').then(r=>r.ok?r.json():null).catch(()=>null),
      fetch('/api/history').then(r=>r.ok?r.json():null).catch(()=>null),
    ]);
    if(s) state.stats=s;
    if(a?.length) state.alerts=a;
    if(h?.length) state.history=h;
    renderStats(); renderFeed(); renderHistory();
  } catch{}
})();

// Re-apply 3D tilt to dynamically added cards
const tiltObs=new MutationObserver(()=>{
  document.querySelectorAll('.glass-tilt').forEach(c=>{
    if(c._tilt) return; c._tilt=true;
    c.addEventListener('mousemove',e=>{ const r=c.getBoundingClientRect(); const x=(e.clientX-r.left)/r.width-.5; const y=(e.clientY-r.top)/r.height-.5; c.style.transform=`perspective(1200px) rotateY(${x*8}deg) rotateX(${-y*8}deg) translateZ(8px)`; });
    c.addEventListener('mouseleave',()=>{ c.style.transform='perspective(1200px) rotateY(0) rotateX(0) translateZ(0)'; });
  });
});
tiltObs.observe(document.body,{childList:true,subtree:true});
</script>
